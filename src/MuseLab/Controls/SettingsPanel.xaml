<UserControl x:Class="MuseLab.Controls.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Settings"
                   FontSize="16"
                   Foreground="White"
                   Margin="0,0,0,10"/>

        <!-- 설정 목록 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 곡 정보 표시 설정 -->
                <Border Background="#FF3A3A3A"
                        CornerRadius="6"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <Button x:Name="SongInfoToggle"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="10,8"
                                Cursor="Hand"
                                HorizontalContentAlignment="Left"
                                Click="SongInfoToggle_Click"
                                MouseRightButtonDown="SongInfoToggle_RightClick">
                            <TextBlock x:Name="SongInfoToggleText"
                                      Text="곡 정보 표시"
                                      FontSize="13"
                                      Foreground="White"
                                      FontWeight="Bold"/>
                        </Button>

                        <!-- 상세 설정 패널 -->
                        <Border x:Name="SongInfoDetailPanel"
                               Visibility="Collapsed"
                               Background="#FF2A2A2A"
                               Padding="10,5,10,10">
                            <StackPanel>
                                <CheckBox x:Name="ShowDifficultyCheck"
                                         Content="난이도 표시"
                                         Foreground="White"
                                         FontSize="12"
                                         IsChecked="True"
                                         Margin="0,5,0,5"
                                         Checked="ShowDifficultyCheck_Changed"
                                         Unchecked="ShowDifficultyCheck_Changed"/>
                                <CheckBox x:Name="ShowLevelCheck"
                                         Content="레벨 표시"
                                         Foreground="White"
                                         FontSize="12"
                                         IsChecked="True"
                                         Margin="0,0,0,5"
                                         Checked="ShowLevelCheck_Changed"
                                         Unchecked="ShowLevelCheck_Changed"/>
                                <CheckBox x:Name="ShowBorderCheck"
                                         Content="외곽선 추가"
                                         Foreground="White"
                                         FontSize="12"
                                         IsChecked="False"
                                         Margin="0,0,0,5"
                                         Checked="ShowBorderCheck_Changed"
                                         Unchecked="ShowBorderCheck_Changed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 오버레이 편집 버튼 -->
                <Button x:Name="ToggleEditModeButton"
                        Content="오버레이 편집"
                        Background="#FF6C757D"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="10,6"
                        Margin="0,7,0,0"
                        Height="32"
                        FontSize="13"
                        Cursor="Hand"
                        Click="ToggleEditModeButton_Click"/>
            </StackPanel>
        </ScrollViewer>

        <!-- 프로그램 종료 -->
        <Button x:Name="ExitButton"
                Grid.Row="2"
                Content="프로그램 종료"
                Background="#FFDC3545"
                Foreground="White"
                BorderThickness="0"
                Padding="0"
                Margin="0,15,0,0"
                Height="36"
                FontSize="13"
                FontWeight="SemiBold"
                Cursor="Hand"
                VerticalAlignment="Bottom"
                Click="ExitButton_Click"/>

        <!-- 검색 섹션 -->
        <StackPanel Grid.Row="3" Margin="0,10,0,0">
            <TextBlock Text="Song Search"
                       FontSize="14"
                       Foreground="White"
                       Margin="0,0,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchBox"
                        Grid.Column="0"
                        Background="#FF3A3A3A"
                        Foreground="White"
                        BorderBrush="#FF555555"
                        BorderThickness="1"
                        Padding="8"
                        FontSize="13"
                        VerticalContentAlignment="Center"
                        Height="32"
                        GotFocus="SearchBox_GotFocus"
                        TextChanged="SearchBox_TextChanged"
                        KeyDown="SearchBox_KeyDown"/>

                <Button x:Name="SearchButton"
                       Grid.Column="1"
                       Content="Search"
                       Background="#FF2D9CDB"
                       Foreground="White"
                       BorderThickness="0"
                       Padding="15,8"
                       Margin="8,0,0,0"
                       Cursor="Hand"
                       Height="32"
                       Click="SearchButton_Click"/>
            </Grid>

            <!-- 필터 옵션 -->
            <Expander Header="필터"
                      Foreground="White"
                      Margin="0,8,0,0"
                      Background="Transparent"
                      BorderThickness="0">
                <StackPanel Margin="0,8,0,0">
                    <!-- 레벨 범위 -->
                    <TextBlock Text="레벨 범위"
                              FontSize="12"
                              Foreground="#FFBBBBBB"
                              Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="LevelMinBox"
                                Grid.Column="0"
                                Background="#FF3A3A3A"
                                Foreground="White"
                                BorderBrush="#FF555555"
                                BorderThickness="1"
                                Padding="6"
                                FontSize="12"
                                Height="28"
                                VerticalContentAlignment="Center"
                                PreviewTextInput="LevelBox_PreviewTextInput"
                                Text=""/>

                        <TextBlock Grid.Column="1"
                                  Text=" ~ "
                                  Foreground="White"
                                  VerticalAlignment="Center"
                                  Margin="4,0"/>

                        <TextBox x:Name="LevelMaxBox"
                                Grid.Column="2"
                                Background="#FF3A3A3A"
                                Foreground="White"
                                BorderBrush="#FF555555"
                                BorderThickness="1"
                                Padding="6"
                                FontSize="12"
                                Height="28"
                                VerticalContentAlignment="Center"
                                PreviewTextInput="LevelBox_PreviewTextInput"
                                Text=""/>
                    </Grid>

                    <!-- 난이도 필터 -->
                    <TextBlock Text="난이도"
                              FontSize="12"
                              Foreground="#FFBBBBBB"
                              Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button x:Name="CourseAllButton"
                               Content="모두"
                               Background="#FF2D9CDB"
                               Foreground="White"
                               BorderThickness="0"
                               Padding="12,6"
                               FontSize="12"
                               Height="28"
                               MinWidth="60"
                               Cursor="Hand"
                               Click="CourseButton_Click"/>
                        <Button x:Name="CourseMasterButton"
                               Content="Master"
                               Background="#FF3A3A3A"
                               Foreground="White"
                               BorderThickness="0"
                               Padding="12,6"
                               Margin="4,0,0,0"
                               FontSize="12"
                               Height="28"
                               MinWidth="60"
                               Cursor="Hand"
                               Click="CourseButton_Click"/>
                        <Button x:Name="CourseHiddenButton"
                               Content="Hidden"
                               Background="#FF3A3A3A"
                               Foreground="White"
                               BorderThickness="0"
                               Padding="12,6"
                               Margin="4,0,0,0"
                               FontSize="12"
                               Height="28"
                               MinWidth="60"
                               Cursor="Hand"
                               Click="CourseButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </Expander>
        </StackPanel>
    </Grid>
</UserControl>
