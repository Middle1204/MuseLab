<UserControl x:Class="MuseLab.Controls.SearchResultsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MuseLab;component/Styles/SharedStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Search Results"
                       FontSize="16"
                       Foreground="White"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"/>

            <Button x:Name="RandomPickButton"
                    Grid.Column="1"
                    Content="🎲"
                    Background="#FF2D9CDB"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="16"
                    Width="32"
                    Height="24"
                    Margin="0,0,8,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Cursor="Hand"
                    ToolTip="랜덤 선곡"
                    Click="RandomPickButton_Click"/>

            <Button x:Name="CloseSearchButton"
                    Grid.Column="2"
                    Content="×"
                    Background="Transparent"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="20"
                    Width="24"
                    Height="24"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Cursor="Hand"
                    Click="CloseSearchButton_Click"/>
        </Grid>

        <!-- 검색 결과 목록 -->
        <Grid Grid.Row="1">
            <ScrollViewer x:Name="SearchResultsScrollViewer"
                         Style="{StaticResource CustomScrollViewerStyle}"
                         VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="SearchResultsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FF3A3A3A"
                                   CornerRadius="8"
                                   Padding="12"
                                   Margin="0,0,0,8">
                                <StackPanel>
                                    <!-- 곡 제목 -->
                                    <TextBlock Text="{Binding Title}"
                                              FontSize="16"
                                              FontWeight="SemiBold"
                                              Foreground="White"
                                              TextTrimming="CharacterEllipsis"
                                              Margin="0,0,0,6"
                                              Cursor="Hand"
                                              MouseLeftButtonDown="SongTitle_MouseDown"
                                              MouseLeftButtonUp="SongTitle_MouseUp"
                                              MouseLeave="SongTitle_MouseLeave"
                                              ToolTip="클릭하여 복사"
                                              ToolTipService.InitialShowDelay="0"
                                              ToolTipService.ShowDuration="10000"/>

                                    <!-- 작곡가 -->
                                    <TextBlock FontSize="12"
                                              Foreground="#FFBBBBBB"
                                              Margin="0,0,0,8">
                                        <Run Text="Composer: "/>
                                        <Run Text="{Binding Composer}" FontWeight="Medium"/>
                                    </TextBlock>

                                    <!-- 난이도 & 레벨 -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Border Background="#FF2D9CDB"
                                               CornerRadius="4"
                                               Padding="6,3"
                                               Margin="0,0,6,0">
                                            <TextBlock Text="{Binding Course}"
                                                      FontSize="11"
                                                      Foreground="White"
                                                      FontWeight="SemiBold"/>
                                        </Border>

                                        <Border Background="#FFFF6B6B"
                                               CornerRadius="4"
                                               Padding="6,3">
                                            <TextBlock FontSize="11"
                                                      Foreground="White"
                                                      FontWeight="SemiBold">
                                                <Run Text="Lv. "/>
                                                <Run Text="{Binding Level}"/>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>

                                    <!-- 노트 수 및 BPM -->
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="Notes: " FontSize="11" Foreground="#FF888888"/>
                                            <TextBlock Text="{Binding Notes}" FontSize="11" Foreground="#FFCCCCCC" FontWeight="Medium"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="BPM: " FontSize="11" Foreground="#FF888888"/>
                                            <TextBlock Text="{Binding Bpm}" FontSize="11" Foreground="#FFCCCCCC" FontWeight="Medium"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                                                           From="#FFFF6B6B"
                                                                           To="#FF3A3A3A"
                                                                           Duration="0:0:1.5"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock x:Name="NoResultsText"
                      Text="No search results found"
                      FontSize="14"
                      Foreground="#FF888888"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Visibility="Collapsed"/>

            <TextBlock x:Name="SearchPromptText"
                      Text="Type to search for songs..."
                      FontSize="14"
                      Foreground="#FF888888"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Visibility="Collapsed"/>
        </Grid>
    </Grid>
</UserControl>
