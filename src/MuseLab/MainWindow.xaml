<Window x:Class="MuseLab.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False">

    <Grid>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

        <!-- 검색 결과 창 -->
        <Border x:Name="SearchResultsPanel"
                Grid.Column="1"
                Width="350"
                Background="#EE2A2A2A"
                CornerRadius="12"
                Margin="370,20,10,20"
                Padding="12"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                Visibility="Collapsed">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Search Results"
                               FontSize="16"
                               Foreground="White"
                               HorizontalAlignment="Left"/>

                    <Button x:Name="CloseSearchButton"
                            Content="×"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="20"
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Cursor="Hand"
                            Click="CloseSearchButton_Click"/>
                </Grid>

                <Grid Grid.Row="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="SearchResultsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FF3A3A3A"
                                           CornerRadius="8"
                                           Padding="10"
                                           Margin="0,0,0,8"
                                           Cursor="Hand">
                                        <StackPanel>
                                            <TextBlock Text="{Binding SongTitle}"
                                                      FontSize="14"
                                                      FontWeight="SemiBold"
                                                      Foreground="White"
                                                      TextTrimming="CharacterEllipsis"/>

                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <Border Background="#FF2D9CDB"
                                                       CornerRadius="4"
                                                       Padding="4,2"
                                                       Margin="0,0,4,0">
                                                    <TextBlock Text="{Binding Difficulty}"
                                                              FontSize="10"
                                                              Foreground="White"/>
                                                </Border>

                                                <TextBlock Text="{Binding Level}"
                                                          FontSize="11"
                                                          Foreground="#FFBBBBBB"
                                                          VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- 검색 결과 없음 메시지 -->
                    <TextBlock x:Name="NoResultsText"
                              Text="No search results found"
                              FontSize="14"
                              Foreground="#FF888888"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Visibility="Collapsed"/>
                </Grid>
            </Grid>
        </Border>

        <!-- 설정 패널 -->
        <Border x:Name="SettingsPanel"
                Grid.Column="1"
                Width="350"
                Background="#EE2A2A2A"
                CornerRadius="12"
                Margin="0,0,10,0"
                Padding="12"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                Visibility="Collapsed">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Settings"
                           FontSize="16"
                           Foreground="White"
                           Margin="0,0,0,10"/>

                <!-- 예시 설정 -->
                <StackPanel Grid.Row="1">
                    <CheckBox x:Name="ToggleLevel"
                              Content="Show Level"
                              Foreground="White"
                              IsChecked="True"/>

                    <CheckBox x:Name="ToggleDifficulty"
                              Content="Show Difficulty"
                              Foreground="White"
                              IsChecked="True"/>
                </StackPanel>

                <!-- 프로그램 종료 -->
                <Button x:Name="ExitButton"
                        Grid.Row="2"
                        Content="프로그램 종료"
                        Background="#FFDC3545"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="0"
                        Margin="0,15,0,0"
                        Height="36"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        VerticalAlignment="Bottom"
                        Click="ExitButton_Click"/>

                <!-- 검색 섹션 -->
                <StackPanel Grid.Row="3" Margin="0,10,0,0">
                    <TextBlock Text="Song Search"
                               FontSize="14"
                               Foreground="White"
                               Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="SearchBox"
                                Grid.Column="0"
                                Background="#FF3A3A3A"
                                Foreground="White"
                                BorderBrush="#FF555555"
                                BorderThickness="1"
                                Padding="8"
                                FontSize="13"
                                VerticalContentAlignment="Center"
                                Height="32"
                                KeyDown="SearchBox_KeyDown"/>

                        <Button x:Name="SearchButton"
                               Grid.Column="1"
                               Content="Search"
                               Background="#FF2D9CDB"
                               Foreground="White"
                               BorderThickness="0"
                               Padding="15,8"
                               Margin="8,0,0,0"
                               Cursor="Hand"
                               Height="32"
                               Click="SearchButton_Click"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 곡 정보 표시 -->
        <Border Grid.Column="2"
                Width="320"
                Height="110"
                CornerRadius="16"
                Background="#CC1E1E1E"
                Padding="14"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,20,20">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="NOW PLAYING"
                           FontSize="11"
                           Foreground="#FF8A8A8A"/>

                <!-- 본문 -->
                <StackPanel Grid.Row="1" Margin="0,6,0,0">

                    <TextBlock x:Name="SongText"
                               Text="Song Title"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="White"
                               TextTrimming="CharacterEllipsis"/>

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">

                        <!-- 난이도 -->
                        <Border Background="#FF2D9CDB"
                                CornerRadius="6"
                                Padding="6,2"
                                Margin="0,0,6,0">

                            <TextBlock x:Name="DifficultyText"
                                       Text="HARD"
                                       FontSize="11"
                                       Foreground="White"/>
                        </Border>

                        <!-- 레벨 -->
                        <TextBlock x:Name="LevelText"
                                   Text="Lv.10"
                                   FontSize="12"
                                   Foreground="#FFBBBBBB"
                                   VerticalAlignment="Center"/>

                    </StackPanel>

                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>