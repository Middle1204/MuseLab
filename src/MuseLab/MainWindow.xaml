<Window x:Class="MuseLab.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False">

    <Grid>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="300"/>
        <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

        <!-- 설정 패널 -->
        <Border x:Name="SettingsPanel"
                Grid.Column="0"
                Background="#EE2A2A2A"
                CornerRadius="12"
                Margin="0,0,10,0"
                Padding="12"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                Visibility="Collapsed">

            <StackPanel>
                <TextBlock Text="Settings"
                           FontSize="16"
                           Foreground="White"
                           Margin="0,0,0,10"/>

                <!-- 예시 설정 -->
                <CheckBox x:Name="ToggleLevel"
                          Content="Show Level"
                          Foreground="White"
                          IsChecked="True"/>

                <CheckBox x:Name="ToggleDifficulty"
                          Content="Show Difficulty"
                          Foreground="White"
                          IsChecked="True"/>

            </StackPanel>
        </Border>

        <!-- 곡 정보 표시 -->
        <Border Grid.Column="1"
                Width="320"
                Height="110"
                CornerRadius="16"
                Background="#CC1E1E1E"
                Padding="14"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,20,20">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="NOW PLAYING"
                           FontSize="11"
                           Foreground="#FF8A8A8A"/>

                <!-- 본문 -->
                <StackPanel Grid.Row="1" Margin="0,6,0,0">

                    <TextBlock x:Name="SongText"
                               Text="Song Title"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="White"
                               TextTrimming="CharacterEllipsis"/>

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">

                        <!-- 난이도 -->
                        <Border Background="#FF2D9CDB"
                                CornerRadius="6"
                                Padding="6,2"
                                Margin="0,0,6,0">

                            <TextBlock x:Name="DifficultyText"
                                       Text="HARD"
                                       FontSize="11"
                                       Foreground="White"/>
                        </Border>

                        <!-- 레벨 -->
                        <TextBlock x:Name="LevelText"
                                   Text="Lv.10"
                                   FontSize="12"
                                   Foreground="#FFBBBBBB"
                                   VerticalAlignment="Center"/>

                    </StackPanel>

                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>