<Window x:Class="MuseLab.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- 스크롤바 스타일 -->
        <Style x:Key="CustomScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Background" Value="#FF555555"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                   CornerRadius="4"
                                                                   Margin="2,0"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FF888888"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter Property="Background" Value="#FF2D9CDB"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomScrollViewerStyle" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1" 
                                      x:Name="PART_VerticalScrollBar"
                                      Orientation="Vertical"
                                      Maximum="{TemplateBinding ScrollableHeight}"
                                      ViewportSize="{TemplateBinding ViewportHeight}"
                                      Value="{TemplateBinding VerticalOffset}"
                                      Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                      Style="{StaticResource CustomScrollBarStyle}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 설정 패널 슬라이드 인 애니메이션 -->
        <Storyboard x:Key="SettingsSlideIn">
            <DoubleAnimation Storyboard.TargetName="SettingsPanelTransform"
                           Storyboard.TargetProperty="X"
                           From="-370"
                           To="0"
                           Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="SettingsPanel"
                           Storyboard.TargetProperty="Opacity"
                           From="0"
                           To="1"
                           Duration="0:0:0.3"/>
        </Storyboard>

        <!-- 설정 패널 슬라이드 아웃 애니메이션 -->
        <Storyboard x:Key="SettingsSlideOut">
            <DoubleAnimation Storyboard.TargetName="SettingsPanelTransform"
                           Storyboard.TargetProperty="X"
                           From="0"
                           To="-370"
                           Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="SettingsPanel"
                           Storyboard.TargetProperty="Opacity"
                           From="1"
                           To="0"
                           Duration="0:0:0.25"/>
        </Storyboard>

        <!-- 검색 결과 패널 슬라이드 인 애니메이션 -->
        <Storyboard x:Key="SearchSlideIn">
            <DoubleAnimation Storyboard.TargetName="SearchResultsTransform"
                           Storyboard.TargetProperty="X"
                           From="-370"
                           To="0"
                           Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="SearchResultsPanel"
                           Storyboard.TargetProperty="Opacity"
                           From="0"
                           To="1"
                           Duration="0:0:0.3"/>
        </Storyboard>

        <!-- 검색 결과 패널 슬라이드 아웃 애니메이션 -->
        <Storyboard x:Key="SearchSlideOut">
            <DoubleAnimation Storyboard.TargetName="SearchResultsTransform"
                           Storyboard.TargetProperty="X"
                           From="0"
                           To="-370"
                           Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="SearchResultsPanel"
                           Storyboard.TargetProperty="Opacity"
                           From="1"
                           To="0"
                           Duration="0:0:0.25"/>
        </Storyboard>
    </Window.Resources>


    <Grid>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

        <!-- 검색 결과 -->
        <Border x:Name="SearchResultsPanel"
                Grid.Column="1"
                Width="350"
                Background="#EE2A2A2A"
                CornerRadius="12"
                Margin="370,20,10,20"
                Padding="12"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                Visibility="Collapsed"
                Opacity="0"
                RenderTransformOrigin="0,0">
            <Border.RenderTransform>
                <TranslateTransform x:Name="SearchResultsTransform" X="-370"/>
            </Border.RenderTransform>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Search Results"
                               FontSize="16"
                               Foreground="White"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"/>

                    <Button x:Name="RandomPickButton"
                            Grid.Column="1"
                            Content="🎲"
                            Background="#FF2D9CDB"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="16"
                            Width="32"
                            Height="24"
                            Margin="0,0,8,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Cursor="Hand"
                            Click="RandomPickButton_Click"
                            ToolTip="랜덤 선곡"/>

                    <Button x:Name="CloseSearchButton"
                            Grid.Column="2"
                            Content="×"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="20"
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Cursor="Hand"
                            Click="CloseSearchButton_Click"/>
                </Grid>

                <Grid Grid.Row="1">
                    <ScrollViewer x:Name="SearchResultsScrollViewer" 
                                 Style="{StaticResource CustomScrollViewerStyle}"
                                 VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="SearchResultsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FF3A3A3A"
                                           CornerRadius="8"
                                           Padding="12"
                                           Margin="0,0,0,8"
                                           x:Name="SearchResultBorder">
                                        <StackPanel>
                                            <!-- 곡 제목 -->
                                            <TextBlock Text="{Binding Title}"
                                                      FontSize="16"
                                                      FontWeight="SemiBold"
                                                      Foreground="White"
                                                      TextTrimming="CharacterEllipsis"
                                                      Margin="0,0,0,6"
                                                      Cursor="Hand"
                                                      MouseLeftButtonDown="SongTitle_MouseDown"
                                                      MouseLeftButtonUp="SongTitle_MouseUp"
                                                      MouseLeave="SongTitle_MouseLeave"
                                                      ToolTip="클릭하여 복사"
                                                      ToolTipService.InitialShowDelay="0"
                                                      ToolTipService.ShowDuration="10000"/>

                                            <!-- 작곡가 -->
                                            <TextBlock FontSize="12"
                                                      Foreground="#FFBBBBBB"
                                                      Margin="0,0,0,8">
                                                <Run Text="Composer: "/>
                                                <Run Text="{Binding Composer}" FontWeight="Medium"/>
                                            </TextBlock>

                                            <!-- 난이도 & 레벨 -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <Border Background="#FF2D9CDB"
                                                       CornerRadius="4"
                                                       Padding="6,3"
                                                       Margin="0,0,6,0">
                                                    <TextBlock Text="{Binding Course}"
                                                              FontSize="11"
                                                              Foreground="White"
                                                              FontWeight="SemiBold"/>
                                                </Border>

                                                <Border Background="#FFFF6B6B"
                                                       CornerRadius="4"
                                                       Padding="6,3">
                                                    <TextBlock FontSize="11"
                                                              Foreground="White"
                                                              FontWeight="SemiBold">
                                                        <Run Text="Lv. "/>
                                                        <Run Text="{Binding Level}"/>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>

                                            <!-- 노트 수 및 BPM -->
                                            <Grid Margin="0,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <TextBlock Text="Notes: "
                                                              FontSize="11"
                                                              Foreground="#FF888888"/>
                                                    <TextBlock Text="{Binding Notes}"
                                                              FontSize="11"
                                                              Foreground="#FFCCCCCC"
                                                              FontWeight="Medium"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <TextBlock Text="BPM: "
                                                              FontSize="11"
                                                              Foreground="#FF888888"/>
                                                    <TextBlock Text="{Binding Bpm}"
                                                              FontSize="11"
                                                              Foreground="#FFCCCCCC"
                                                              FontWeight="Medium"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                                                                   From="#FFFF6B6B"
                                                                                   To="#FF3A3A3A"
                                                                                   Duration="0:0:1.5"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- 검색 결과 없음 텍스트 -->
                    <TextBlock x:Name="NoResultsText"
                              Text="No search results found"
                              FontSize="14"
                              Foreground="#FF888888"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Visibility="Collapsed"/>

                    <!-- 검색 대기 텍스트 -->
                    <TextBlock x:Name="SearchPromptText"
                              Text="Type to search for songs..."
                              FontSize="14"
                              Foreground="#FF888888"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Visibility="Collapsed"/>
                </Grid>
            </Grid>
        </Border>

        <!-- 설정 패널 -->
        <Border x:Name="SettingsPanel"
                Grid.Column="1"
                Width="350"
                Background="#EE2A2A2A"
                CornerRadius="12"
                Margin="0,0,10,0"
                Padding="12"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                Visibility="Collapsed"
                Opacity="0"
                RenderTransformOrigin="0,0">
            <Border.RenderTransform>
                <TranslateTransform x:Name="SettingsPanelTransform" X="-370"/>
            </Border.RenderTransform>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Settings"
                           FontSize="16"
                           Foreground="White"
                           Margin="0,0,0,10"/>

                <!-- 설정 목록 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- 곡 정보 표시 설정 -->
                        <Border Background="#FF3A3A3A"
                                CornerRadius="6"
                                Margin="0,0,0,8">
                            <StackPanel>
                                <Button x:Name="SongInfoToggle"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="10,8"
                                        Cursor="Hand"
                                        HorizontalContentAlignment="Left"
                                        Click="SongInfoToggle_Click"
                                        MouseRightButtonDown="SongInfoToggle_RightClick">
                                    <TextBlock x:Name="SongInfoToggleText"
                                              Text="곡 정보 표시"
                                              FontSize="13"
                                              Foreground="White"
                                              FontWeight="Bold"/>
                                </Button>

                                <!-- 상세 설정 패널 -->
                                <Border x:Name="SongInfoDetailPanel"
                                       Visibility="Collapsed"
                                       Background="#FF2A2A2A"
                                       Padding="10,5,10,10">
                                    <StackPanel>
                                        <CheckBox x:Name="ShowDifficultyCheck"
                                                 Content="난이도 표시"
                                                 Foreground="White"
                                                 FontSize="12"
                                                 IsChecked="True"
                                                 Margin="0,5,0,5"
                                                 Checked="ShowDifficultyCheck_Changed"
                                                 Unchecked="ShowDifficultyCheck_Changed"/>
                                        <CheckBox x:Name="ShowLevelCheck"
                                                 Content="레벨 표시"
                                                 Foreground="White"
                                                 FontSize="12"
                                                 IsChecked="True"
                                                 Margin="0,0,0,5"
                                                 Checked="ShowLevelCheck_Changed"
                                                 Unchecked="ShowLevelCheck_Changed"/>
                                        <CheckBox x:Name="ShowBorderCheck"
                                                 Content="외곽선 추가"
                                                 Foreground="White"
                                                 FontSize="12"
                                                 IsChecked="False"
                                                 Margin="0,0,0,5"
                                                 Checked="ShowBorderCheck_Changed"
                                                 Unchecked="ShowBorderCheck_Changed"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- 오버레이 편집 버튼 -->
                        <Button x:Name="ToggleEditModeButton"
                                Content="오버레이 편집"
                                Background="#FF6C757D"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="10,6"
                                Margin="0,7,0,0"
                                Height="32"
                                FontSize="13"
                                Cursor="Hand"
                                Click="ToggleEditModeButton_Click"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- 프로그램 종료 -->
                <Button x:Name="ExitButton"
                        Grid.Row="2"
                        Content="프로그램 종료"
                        Background="#FFDC3545"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="0"
                        Margin="0,15,0,0"
                        Height="36"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        VerticalAlignment="Bottom"
                        Click="ExitButton_Click"/>

                <!-- 검색 섹션 -->
                <StackPanel Grid.Row="3" Margin="0,10,0,0">
                    <TextBlock Text="Song Search"
                               FontSize="14"
                               Foreground="White"
                               Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="SearchBox"
                                Grid.Column="0"
                                Background="#FF3A3A3A"
                                Foreground="White"
                                BorderBrush="#FF555555"
                                BorderThickness="1"
                                Padding="8"
                                FontSize="13"
                                VerticalContentAlignment="Center"
                                Height="32"
                                GotFocus="SearchBox_GotFocus"
                                TextChanged="SearchBox_TextChanged"
                                KeyDown="SearchBox_KeyDown"/>

                        <Button x:Name="SearchButton"
                               Grid.Column="1"
                               Content="Search"
                               Background="#FF2D9CDB"
                               Foreground="White"
                               BorderThickness="0"
                               Padding="15,8"
                               Margin="8,0,0,0"
                               Cursor="Hand"
                               Height="32"
                               Click="SearchButton_Click"/>
                    </Grid>

                    <!-- 필터 옵션 -->
                    <Expander Header="필터"
                              Foreground="White"
                              Margin="0,8,0,0"
                              Background="Transparent"
                              BorderThickness="0">
                        <StackPanel Margin="0,8,0,0">
                            <!-- 레벨 범위 -->
                            <TextBlock Text="레벨 범위"
                                      FontSize="12"
                                      Foreground="#FFBBBBBB"
                                      Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="LevelMinBox"
                                        Grid.Column="0"
                                        Background="#FF3A3A3A"
                                        Foreground="White"
                                        BorderBrush="#FF555555"
                                        BorderThickness="1"
                                        Padding="6"
                                        FontSize="12"
                                        Height="28"
                                        VerticalContentAlignment="Center"
                                        PreviewTextInput="LevelBox_PreviewTextInput"
                                        Text=""/>

                                <TextBlock Grid.Column="1"
                                          Text=" ~ "
                                          Foreground="White"
                                          VerticalAlignment="Center"
                                          Margin="4,0"/>

                                <TextBox x:Name="LevelMaxBox"
                                        Grid.Column="2"
                                        Background="#FF3A3A3A"
                                        Foreground="White"
                                        BorderBrush="#FF555555"
                                        BorderThickness="1"
                                        Padding="6"
                                        FontSize="12"
                                        Height="28"
                                        VerticalContentAlignment="Center"
                                        PreviewTextInput="LevelBox_PreviewTextInput"
                                        Text=""/>
                            </Grid>

                            <!-- 난이도 필터 -->
                            <TextBlock Text="난이도"
                                      FontSize="12"
                                      Foreground="#FFBBBBBB"
                                      Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button x:Name="CourseAllButton"
                                       Content="모두"
                                       Background="#FF2D9CDB"
                                       Foreground="White"
                                       BorderThickness="0"
                                       Padding="12,6"
                                       FontSize="12"
                                       Height="28"
                                       MinWidth="60"
                                       Cursor="Hand"
                                       Click="CourseButton_Click"/>
                                <Button x:Name="CourseMasterButton"
                                       Content="Master"
                                       Background="#FF3A3A3A"
                                       Foreground="White"
                                       BorderThickness="0"
                                       Padding="12,6"
                                       Margin="4,0,0,0"
                                       FontSize="12"
                                       Height="28"
                                       MinWidth="60"
                                       Cursor="Hand"
                                       Click="CourseButton_Click"/>
                                <Button x:Name="CourseHiddenButton"
                                       Content="Hidden"
                                       Background="#FF3A3A3A"
                                       Foreground="White"
                                       BorderThickness="0"
                                       Padding="12,6"
                                       Margin="4,0,0,0"
                                       FontSize="12"
                                       Height="28"
                                       MinWidth="60"
                                       Cursor="Hand"
                                       Click="CourseButton_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 곡 정보 표시 -->
        <Border x:Name="SongInfoBorder"
                Grid.Column="2"
                Width="320"
                Height="110"
                CornerRadius="16"
                Background="#CC1E1E1E"
                Padding="14"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,20,20"
                MouseLeftButtonDown="SongInfoBorder_MouseLeftButtonDown"
                MouseLeftButtonUp="SongInfoBorder_MouseLeftButtonUp"
                MouseMove="SongInfoBorder_MouseMove">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="NOW PLAYING"
                           FontSize="11"
                           Foreground="#FF8A8A8A"/>

                <!-- 본문 -->
                <StackPanel Grid.Row="1" Margin="0,6,0,0">

                    <TextBlock x:Name="SongText"
                               Text="Song Title"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="White"
                               TextTrimming="CharacterEllipsis"/>

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">

                        <!-- 난이도 -->
                        <Border x:Name="DifficultyBorder"
                                Background="#FF2D9CDB"
                                CornerRadius="6"
                                Padding="6,2"
                                Margin="0,0,6,0">

                            <TextBlock x:Name="DifficultyText"
                                       Text="HARD"
                                       FontSize="11"
                                       Foreground="White"/>
                        </Border>

                        <!-- 레벨 -->
                        <TextBlock x:Name="LevelText"
                                   Text="Lv.10"
                                   FontSize="12"
                                   Foreground="#FFBBBBBB"
                                   VerticalAlignment="Center"/>

                    </StackPanel>

                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>