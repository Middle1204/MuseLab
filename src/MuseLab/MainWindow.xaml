<Window x:Class="MuseLab.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MuseLab.Controls"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MuseLab;component/Styles/SharedStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Settings panel slide-in animation -->
        <Storyboard x:Key="SettingsSlideIn">
            <DoubleAnimation Storyboard.TargetName="SettingsPanelTransform"
                           Storyboard.TargetProperty="X"
                           From="-370" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="SettingsPanelWrapper"
                           Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.3"/>
        </Storyboard>

            <!-- Settings panel slide-out animation -->
        <Storyboard x:Key="SettingsSlideOut">
            <DoubleAnimation Storyboard.TargetName="SettingsPanelTransform"
                           Storyboard.TargetProperty="X"
                           From="0" To="-370" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="SettingsPanelWrapper"
                           Storyboard.TargetProperty="Opacity"
                           From="1" To="0" Duration="0:0:0.25"/>
        </Storyboard>

            <!-- Search results panel slide-in animation -->
        <Storyboard x:Key="SearchSlideIn">
            <DoubleAnimation Storyboard.TargetName="SearchResultsTransform"
                           Storyboard.TargetProperty="X"
                           From="-370" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="SearchResultsWrapper"
                           Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.3"/>
        </Storyboard>

            <!-- Search results panel slide-out animation -->
        <Storyboard x:Key="SearchSlideOut">
            <DoubleAnimation Storyboard.TargetName="SearchResultsTransform"
                           Storyboard.TargetProperty="X"
                           From="0" To="-370" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="SearchResultsWrapper"
                           Storyboard.TargetProperty="Opacity"
                           From="1" To="0" Duration="0:0:0.25"/>
        </Storyboard>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Search results panel -->
        <Border x:Name="SearchResultsWrapper"
                Width="350"
                Background="#EE2A2A2A"
                CornerRadius="12"
                Margin="370,20,10,20"
                Padding="12"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                Visibility="Collapsed"
                Opacity="0"
                RenderTransformOrigin="0,0">
            <Border.RenderTransform>
                <TranslateTransform x:Name="SearchResultsTransform" X="-370"/>
            </Border.RenderTransform>
            <controls:SearchResultsPanel x:Name="SearchResultsControl"
                                         CloseRequested="SearchResultsControl_CloseRequested"/>
        </Border>

        <!-- Settings panel -->
        <Border x:Name="SettingsPanelWrapper"
                Width="350"
                Background="#EE2A2A2A"
                CornerRadius="12"
                Margin="0,0,10,0"
                Padding="12"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                Visibility="Collapsed"
                Opacity="0"
                RenderTransformOrigin="0,0">
            <Border.RenderTransform>
                <TranslateTransform x:Name="SettingsPanelTransform" X="-370"/>
            </Border.RenderTransform>
            <controls:SettingsPanel x:Name="SettingsPanelControl"
                                    ExitRequested="SettingsPanelControl_ExitRequested"
                                    SearchRequested="SettingsPanelControl_SearchRequested"
                                    SearchTextChanged="SettingsPanelControl_SearchTextChanged"
                                    SearchFocused="SettingsPanelControl_SearchFocused"
                                    SongInfoToggled="SettingsPanelControl_SongInfoToggled"
                                    DifficultyVisibilityChanged="SettingsPanelControl_DifficultyVisibilityChanged"
                                    LevelVisibilityChanged="SettingsPanelControl_LevelVisibilityChanged"
                                    BorderVisibilityChanged="SettingsPanelControl_BorderVisibilityChanged"
                                    EditModeToggled="SettingsPanelControl_EditModeToggled"/>
        </Border>

        <!-- Song info overlay -->
        <controls:SongInfoOverlay x:Name="SongInfoControl"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Bottom"
                                  Margin="0,0,20,20"/>
    </Grid>
</Window>
